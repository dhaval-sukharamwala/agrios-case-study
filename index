        <div class="type-scale" id="typeScale"></div>
      </div>
    </div>
    <div class="grid-2">
      <div class="ds-block reveal">
        <div class="h">Status &amp; components</div>
        <div class="comp-row" style="margin-bottom:16px">
          <button class="btn-sm pri">Start drip</button><button class="btn-sm">Why?</button><span class="ask-pill" style="padding:8px 14px;font-size:13px"><i data-lucide="sparkles"></i>Copilot</span>
        </div>
        <div class="comp-row" style="margin-bottom:16px">
