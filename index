const $=(s,r=document)=>r.querySelector(s), $$=(s,r=document)=>[...r.querySelectorAll(s)];
addEventListener('error',()=>$$('.reveal').forEach(x=>x.classList.add('in')));

/* inline icons */
const ICONS={
 'user':'<circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/>',
 'target':'<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.5"/>',
 'leaf':'<path d="M4 20c0-9 5-14 16-15 1 11-4 16-16 15z"/><path d="M4 20c3-7 7-11 12-12"/>',
 'sparkles':'<path d="M12 3l1.7 4.6L18 9l-4.3 1.4L12 15l-1.7-4.6L6 9l4.3-1.4z"/><path d="M19 14l.8 2.2L22 17l-2.2.8L19 20l-.8-2.2L16 17l2.2-.8z"/>',
 'arrow-right':'<path d="M4 12h15"/><path d="M13 6l6 6-6 6"/>',
 'arrow-up-right':'<path d="M7 17 17 7"/><path d="M8 7h9v9"/>',
 'chevron-right':'<path d="M9 6l6 6-6 6"/>',
 'droplets':'<path d="M12 3.5c3.5 3.6 6 6.6 6 10a6 6 0 0 1-12 0c0-3.4 2.5-6.4 6-10z"/>',
 'minus':'<path d="M5 12h14"/>',
 'plus':'<path d="M12 5v14"/><path d="M5 12h14"/>',
 'layers':'<path d="M12 3 21 8l-9 5-9-5z"/><path d="M3 13l9 5 9-5"/>',
 'clock':'<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
 'eye':'<path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/>',
 'info':'<circle cx="12" cy="12" r="9"/><path d="M12 11v5"/><path d="M12 8h.01"/>',
 'alert-triangle':'<path d="M12 3.5 22 20H2z"/><path d="M12 10v4"/><path d="M12 17h.01"/>',
 'check':'<path d="M5 12l4.5 4.5L19 7"/>',
 'map':'<path d="M9 4 3 6v14l6-2 6 2 6-2V4l-6 2z"/><path d="M9 4v14"/><path d="M15 6v14"/>',
 'trending-up':'<path d="M3 17 9 11l4 4 8-8"/><path d="M15 7h6v6"/>',
 'search':'<circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/>',
 'moon':'<path d="M20 14A8 8 0 0 1 10 4a8 8 0 1 0 10 10z"/>',
 'cpu':'<rect x="6" y="6" width="12" height="12" rx="1.5"/><rect x="9.5" y="9.5" width="5" height="5" rx="0.5"/><path d="M9 3v3M15 3v3M9 18v3M15 18v3M3 9h3M3 15h3M18 9h3M18 15h3"/>',
 'lightbulb':'<path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 0 0-4 12.7c.6.5 1 1.3 1 2.1h6c0-.8.4-1.6 1-2.1A7 7 0 0 0 12 2z"/>',
 'zap':'<path d="M13 3 4 14h7l-1 7 9-11h-7z"/>',
 'microscope':'<path d="M6 20h11"/><path d="M9.5 20a5.5 5.5 0 0 0 8.5-4.6"/><path d="M8.7 14.2 13 5.7l3.2 1.6-4.3 8.5z"/><path d="M9.7 7.3 13 9"/>',
 'wind':'<path d="M3 9h11a3 3 0 1 0-3-4"/><path d="M3 14h15a3 3 0 1 1-3 4"/>',
 'wifi':'<path d="M2.5 8.5a15 15 0 0 1 19 0"/><path d="M5.5 12a10 10 0 0 1 13 0"/><path d="M8.5 15.3a5.5 5.5 0 0 1 7 0"/><path d="M12 19h.01"/>',
 'sprout':'<path d="M12 21v-9"/><path d="M12 12C12 8 9.5 5.5 5 5.5 5 10 7.5 12 12 12z"/><path d="M12 12c0-3.2 2.5-5.5 7-5.5 0 4.5-2.5 5.5-7 5.5z"/>'
};
function renderIcons(root=document){
  root.querySelectorAll('[data-lucide]').forEach(el=>{
    const body=ICONS[el.getAttribute('data-lucide')]; if(!body) return;
    const svg=document.createElementNS('http://www.w3.org/2000/svg','svg');
    svg.setAttribute('viewBox','0 0 24 24');
    svg.setAttribute('class','ic-svg '+(el.getAttribute('class')||''));
    const st=el.getAttribute('style'); if(st) svg.setAttribute('style',st);
    svg.innerHTML=body;
    el.replaceWith(svg);
  });
}

/* section markers */
$$('.sec-num').forEach(n=>{const on=(n.dataset.pat||'').split(',').filter(x=>x!=='').map(Number);
  let h=''; for(let i=0;i<9;i++) h+='<i class="'+(on.includes(i)?'on':'')+'"></i>'; n.innerHTML=h;});

/* nav + progress + smooth scroll */
const nav=$('.nav'), prog=$('.progress');
function onScroll(){const y=window.scrollY; nav.classList.toggle('scrolled',y>24);
  const h=document.documentElement.scrollHeight-window.innerHeight; prog.style.width=(h>0?(y/h*100):0)+'%';}
addEventListener('scroll',onScroll,{passive:true}); onScroll();
$$('[data-go]').forEach(a=>a.addEventListener('click',()=>{const el=document.getElementById(a.dataset.go); if(el) el.scrollIntoView({behavior:'smooth'});}));

/* COMPARE toggle */
const dashHTML=''
+'<div class="cmp-scenario cmp-fade"><span style="color:var(--rust)">\u25CF</span> Scenario · Rain forecast 16:00 · Kadod South</div>'
+'<div class="dash-readout cmp-fade">'
+'<div class="ro"><div class="k">Soil moisture</div><div class="v" style="color:var(--rust)">19%</div></div>'
+'<div class="ro"><div class="k">Rain forecast (16:00)</div><div class="v">1.2<small> mm</small></div></div>'
+'<div class="ro"><div class="k">Wilting point</div><div class="v">22%</div></div>'
+'<div class="ro"><div class="k">Since last irrigation</div><div class="v">12<small> days</small></div></div>'
+'</div>'
+'<div class="cmp-note cmp-fade"><span style="color:var(--rust)">i</span> The dashboard shows the numbers, and they’re right. Working out what they mean \u2014 and the risk of reading them wrong \u2014 is still on you.</div>';
const copHTML=''
+'<div class="cmp-scenario cmp-fade"><span style="color:var(--green-2)">\u25CF</span> Scenario · Rain forecast 16:00 · Kadod South</div>'
+'<div class="cop-answer cmp-fade"><span class="av"><i data-lucide="sparkles"></i></span>'
+'<div class="txt">Rain won\u2019t recover Kadod South. <b>Start a 90-min drip cycle now</b> to prevent root stress before the shower.</div></div>'
+'<div class="cop-reason cmp-fade">'
+'<div class="r"><b>Recovery:</b> 1.2 mm adds only ~1.5% \u2192 reaches ~20.5%, still under the 22% wilting point.</div>'
+'<div class="r"><b>Timing:</b> sugarcane transpiration drops after 17:30, so post-rain uptake is limited.</div>'
+'<div class="r"><b>Action:</b> a 90-min drip delivers 6.5 L/sqm directly to the root zone now.</div>'
+'</div>'
+'<div class="cop-verdict cmp-fade"><span class="x">What happened.</span><span class="y">What to do next.</span></div>';
function setCmp(which){
  $$('.compare-toggle button').forEach(b=>b.classList.toggle('active',b.dataset.cmp===which));
  $('#cmpStage').innerHTML = which==='cop'?copHTML:dashHTML;
  renderIcons($('#cmpStage'));
}
$$('.compare-toggle button').forEach(b=>b.addEventListener('click',()=>setCmp(b.dataset.cmp)));
setCmp('dash');

/* REASONING loop */
const steps=[
 {ic:'eye',n:'Step 01',t:'Observe',d:'First it just gathers what’s happening on the farm, from every source it can read.',li:['Soil and sensor readings','Weather forecasts','Satellite and crop-health scans','Past seasons on this farm']},
 {ic:'cpu',n:'Step 02',t:'Reason',d:'Then it checks those readings against what the crop needs, and works out where things are heading.',li:['Check against the crop’s thresholds','Project where it’s heading','Weigh the risk, and how sure it is']},
 {ic:'lightbulb',n:'Step 03',t:'Recommend',d:'It turns that into one clear next step — and the reason it’s suggesting it.',li:['Say why it matters now','Give the likely outcome','Point to the single best next step']},
 {ic:'zap',n:'Step 04',t:'Act',d:'And it makes that step easy to actually do, then keeps an eye on the result.',li:['Start the irrigation','Book a spray','Add a task for the crew','Then watch how it plays out']}
];
$('#loop').innerHTML=steps.map((s,i)=>''
 +'<div class="loop-step'+(i===0?' active':'')+'" data-i="'+i+'">'
 +'<div class="st-ic"><i data-lucide="'+s.ic+'"></i></div>'
 +'<div class="st-n">'+s.n+'</div><h4>'+s.t+'</h4><div class="st-d">'+s.d+'</div>'
 +'<ul>'+s.li.map(x=>'<li>'+x+'</li>').join('')+'</ul></div>').join('');
$$('.loop-step').forEach(el=>el.addEventListener('click',()=>{
  $$('.loop-step').forEach(x=>x.classList.remove('active')); el.classList.add('active');}));

/* COPILOT suggested-action chips */
$$('.sa-chip').forEach(c=>c.addEventListener('click',()=>{
  const done=c.classList.toggle('done');
  const ci=c.querySelector('.ci');
  if(done){c.dataset.txt=c.lastChild.textContent; c.lastChild.textContent=' Added to today\u2019s plan'; ci.innerHTML='<i data-lucide="check"></i>';}
  else{c.lastChild.textContent=c.dataset.txt;}
  renderIcons(c);
}));

/* DASHBOARD Why toggles */
$$('.ac-btns .btn-sm').forEach(b=>{
  if(b.textContent.trim()==='Why?') b.addEventListener('click',()=>{
    const p=document.getElementById('why-'+b.dataset.why); if(p) p.classList.toggle('open');});
});

/* DECISIONS */
const decisions=[
 {q:'Why open with a recommendation instead of the dashboard?',
  problem:'The traditional pattern drops the grower into charts and expects them to diagnose. That is slow, and it wastes the one thing the AI is good at \u2014 turning data into a conclusion.',
  alt:'Tested a chart-first overview with an AI panel bolted on the side. It read as \u201Cyet another widget\u201D and people still started from the graphs.',
  reason:'If the Copilot is genuinely the product, the first thing on screen should be its read of the day. The dashboard is demoted to evidence you reach for on demand.',
  choice:'Every surface \u2014 home, dashboard, map \u2014 leads with an AI insight and the next action. Raw panels sit below as supporting context.',
  benefit:'The decision is the hero. Growers act in seconds instead of interpreting for minutes.'},
 {q:'Why does every answer carry a \u201CWhy?\u201D',
  problem:'A recommendation you cannot interrogate is a black box, and nobody bets a crop on a black box.',
  alt:'Considered showing confidence scores alone. A number like \u201C87% confident\u201D tells you how sure the model is, not what it reasoned about.',
  reason:'Trust comes from transparency. The grower should be able to expand any suggestion and see the observation, the threshold, and the projection behind it.',
  choice:'A persistent \u201CWhy?\u201D on every recommendation reveals the reasoning chain in the Copilot\u2019s own words, pointing at the exact telemetry.',
  benefit:'The AI becomes a teammate that explains itself, not an oracle you either obey or ignore.'},
 {q:'Why surface data freshness and confidence so prominently?',
  problem:'An AI acting on a sensor that last reported 40 minutes ago can be confidently wrong \u2014 the most dangerous failure mode for an autonomous-feeling product.',
  alt:'Hiding staleness for a cleaner look tested better aesthetically but quietly eroded trust the moment a stale call was caught.',
  reason:'Honesty about the inputs is part of the recommendation. A \u201CStale \u00B7 40 min\u201D tag reframes how much weight to give a number.',
  choice:'Staleness, confidence, and the verifiable-telemetry note are first-class UI, not fine print \u2014 including \u201CAI answers can be verified via sensor logs.\u201D',
  benefit:'The grower calibrates trust correctly, which paradoxically makes them trust the Copilot more.'},
 {q:'Why keep a dashboard at all, if the Copilot is the product?',
  problem:'Removing charts entirely would make the AI unfalsifiable \u2014 and experts like agronomists genuinely need the underlying curves.',
  alt:'A pure chat interface was tempting but stranded power users and left recommendations with nothing to point at.',
  reason:'The dashboard\u2019s job changes rather than disappears: from primary interface to the evidence layer the Copilot cites and experts can drill into.',
  choice:'A full Overview, Monitoring, Crop Health and Reports still exist \u2014 but every view opens with the AI read, and charts are framed as \u201Cwhy\u201D not \u201Cwhat.\u201D',
  benefit:'Novices get decisions; experts get depth; the Copilot always has receipts.'}
];
const blk=(k,v)=>'<div class="blk"><div class="bk">'+k+'</div><div class="bt">'+v+'</div></div>';
$('#decisions-list').innerHTML=decisions.map((d,i)=>''
 +'<div class="decision'+(i===0?' open':'')+'"><button class="dec-head"><span class="ix">D'+(i+1)+'</span><span class="q">'+d.q+'</span><span class="tog"><i data-lucide="'+(i===0?'minus':'plus')+'"></i></span></button>'
 +'<div class="dec-body"><div class="dec-inner">'+blk('Problem',d.problem)+blk('Alternatives weighed',d.alt)+blk('Reasoning',d.reason)+blk('Final choice',d.choice)+blk('Expected benefit',d.benefit)+'</div></div></div>').join('');
$$('.dec-head').forEach(btn=>btn.addEventListener('click',()=>{const d=btn.closest('.decision'),open=d.classList.contains('open');
  $$('.decision').forEach(x=>{x.classList.remove('open');x.querySelector('.tog').innerHTML='<i data-lucide="plus"></i>';});
  if(!open){d.classList.add('open');d.querySelector('.tog').innerHTML='<i data-lucide="minus"></i>';}
  renderIcons();}));

/* DESIGN SYSTEM */
$('#swatches').innerHTML=[['#1E4A36','green-deep'],['#2E7A52','green'],['#4E9B6E','green-2'],['#8FBF9E','green-3'],['#BC5B2A','rust'],['#C79A46','amber']].map(([c,n])=>'<div class="sw" style="background:'+c+'"><span>'+n+'</span></div>').join('');
$('#neutrals').innerHTML=[['#F4F3EC','paper'],['#FFFFFF','surface'],['#1E2419','ink'],['#E6E4DA','line']].map(([c,n])=>'<div style="text-align:center"><div style="width:40px;height:40px;border-radius:8px;background:'+c+';border:1px solid var(--line)"></div><div class="mono" style="font-size:9px;color:var(--faint);margin-top:6px">'+n+'</div></div>').join('');
$('#typeScale').innerHTML=[['64','Aa'],['48','Aa'],['32','Display'],['24','Heading'],['20','Subhead'],['16','Body']].map(([px,t])=>'<div><span class="px">'+px+'</span><span class="sm" style="font-size:'+Math.min(+px,40)+'px">'+t+'</span></div>').join('');
$('#space').innerHTML=[8,16,24,32,48,64].map(s=>'<div><i style="width:'+s+'px;height:'+s+'px"></i><span>'+s+'</span></div>').join('');

/* IMPACT */
$('#impactGrower').innerHTML=[['Decisions get faster','one clear recommendation instead of ten minutes reading charts.','Measure: time from opening the app to the first action'],['Fewer mistimed calls','the timing and the risk get reasoned through, not guessed.','Measure: share of actions taken inside the right window'],['Water and spray go where they’re needed','advice is per field and per problem, not a blanket schedule.','Measure: water and chemical used per hectare vs a fixed schedule'],['Less of it needs an expert','it explains itself, so you don’t have to read the curves yourself.','Measure: how well first-timers do vs experienced users']].map(([b,t,m])=>'<div class="impact-item"><span class="ci"><i data-lucide="check"></i></span><div class="t"><b>'+b+'</b> '+t+'<div class="metric">'+m+'</div></div></div>').join('');
$('#impactBiz').innerHTML=[['A reason to open it daily','something that tells you what to do is worth checking every morning.','Measure: daily and weekly actives, and how many make a call'],['Trust is what drives use','people act on answers they can question and check.','Measure: how often answers get accepted, and how often “Why?” gets opened'],['People stay for the outcomes','the value is in what it helps you do, not the feature list.','Measure: retention of people who act on it vs people who only read charts'],['Hard to copy with a dashboard','the whole product is the reasoning, not the charts.','Measure: deals where the assistant is the reason they chose it']].map(([b,t,m])=>'<div class="impact-item"><span class="ci"><i data-lucide="trending-up"></i></span><div class="t"><b>'+b+'</b> '+t+'<div class="metric">'+m+'</div></div></div>').join('');

/* LESSONS + ROADMAP */
$('#lessons-list').innerHTML=[['Worked','Leading with the decision, not the data, reframed every screen \u2014 the dashboard question became \u201Cwhat evidence does the Copilot cite?\u201D'],['Changed','I stopped designing an \u201CAI panel\u201D and started designing the AI as the product, with charts in a supporting role.'],['Trade-off','Recommendation-first can feel opaque, so the \u201CWhy?\u201D and telemetry-verification became non-negotiable, not nice-to-have.'],['What I cut','I only built the Overview and the Copilot properly \u2014 Monitoring, Crop Health and Reports stayed as nav stubs. I\u2019d rather get one screen and the core interaction right than spread thin across five half-finished ones.'],['Biggest risk','It\u2019s unvalidated. The whole thesis rests on growers trusting a recommendation over a chart \u2014 so that\u2019s the very first thing I\u2019d put in front of real users.'],['Next time','I\u2019d prototype the reasoning-explanation UI even earlier \u2014 it turned out to carry the trust, and the trust carries the product.']].map(([k,p])=>'<div class="lesson"><div class="k">'+k+'</div><p>'+p+'</p></div>').join('');
$('#roadmap').innerHTML=[['microscope','Disease detection','Image diagnosis from a field photo'],['wind','Voice in the field','Hands-free queries while working'],['wifi','Offline-first sync','Full capability on zero bars'],['zap','Guarded auto-actions','Copilot acts within set limits'],['map','Portfolio view','One Copilot across many farms'],['info','Explainability log','An audit trail for every AI call']].map(([ic,t,d])=>'<div class="r"><span class="ci"><i data-lucide="'+ic+'"></i></span><div><div class="t">'+t+'</div><div class="d">'+d+'</div></div></div>').join('');

/* REVEAL + COUNT-UP (guarded) */
const reduce=(typeof matchMedia==='function')&&matchMedia('(prefers-reduced-motion: reduce)').matches;
$$('.reveal').forEach((el,i)=>{el.style.transitionDelay=((i%3)*60)+'ms';});
if('IntersectionObserver' in window){
  const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}}),{threshold:.1,rootMargin:'0px 0px -6% 0px'});
  $$('.reveal').forEach(el=>io.observe(el));
}else{
  $$('.reveal').forEach(x=>x.classList.add('in'));
}

renderIcons();
</script>
</body>
</html>
