<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>AgriOS — The Copilot is the New Dashboard · Case Study</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Caveat:wght@500;600&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap');
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}

.as-root{
  --paper:#F4F3EC; --surface:#FFFFFF; --surface-2:#FAFAF6; --panel:#F0EFE6;
  --ink:#1E2419; --muted:#6C7168; --faint:#9BA093; --line:#E6E4DA; --line-2:#EFEEE6;
  --green:#2E7A52; --green-deep:#1E4A36; --green-2:#4E9B6E; --green-3:#8FBF9E; --green-wash:#E9F1EB;
  --rust:#BC5B2A; --rust-2:#7C3D1E; --rust-wash:#F6E7DC; --amber:#C79A46; --blue:#3E6B8C;
  --serif:'Fraunces',Georgia,serif; --sans:'Inter',system-ui,sans-serif; --mono:'JetBrains Mono',monospace;
  background:var(--paper); color:var(--ink); font-family:var(--sans);
  -webkit-font-smoothing:antialiased; line-height:1.55; font-size:16px; overflow-x:hidden;
}
.as-root ::selection{background:var(--green-deep);color:#fff;}

/* type */
.eyebrow{font-family:var(--mono);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);font-weight:500;}
.h1{font-family:var(--serif);font-weight:500;letter-spacing:-0.035em;line-height:0.99;font-size:clamp(40px,6.6vw,76px);}
.h2{font-family:var(--serif);font-weight:500;letter-spacing:-0.025em;line-height:1.04;font-size:clamp(28px,4.2vw,46px);}
.h3{font-family:var(--serif);font-weight:500;letter-spacing:-0.02em;line-height:1.1;font-size:clamp(20px,2.4vw,26px);}
.lead{font-size:clamp(17px,1.9vw,21px);line-height:1.55;color:var(--muted);}
.mono{font-family:var(--mono);}
.hl-g{color:var(--green-deep);font-weight:500;}
.hl-r{color:var(--rust);font-weight:500;}

/* layout */
.wrap{max-width:1180px;margin:0 auto;padding:0 32px;}
.wrap-narrow{max-width:840px;margin:0 auto;padding:0 32px;}
section{padding:clamp(60px,9vw,124px) 0;position:relative;}
.divider{height:1px;background:var(--line);border:0;}
.band{background:var(--surface-2);border-top:1px solid var(--line);border-bottom:1px solid var(--line);}
.dark-band{background:#16241B;border-top:1px solid #24382B;border-bottom:1px solid #24382B;}

/* nav */
.nav{position:fixed;top:0;left:0;right:0;z-index:50;transition:background .3s,border-color .3s;border-bottom:1px solid transparent;}
.nav.scrolled{background:rgba(244,243,236,.85);backdrop-filter:blur(14px);border-bottom:1px solid var(--line);}
.nav-inner{max-width:1180px;margin:0 auto;padding:14px 32px;display:flex;align-items:center;justify-content:space-between;}
.brand{display:flex;align-items:center;gap:9px;font-family:var(--serif);font-weight:600;font-size:19px;letter-spacing:-0.02em;color:var(--green-deep);}
.brand-mark{width:27px;height:27px;border-radius:8px;background:var(--green-deep);display:grid;place-items:center;color:#fff;}
.nav-links{display:flex;gap:24px;align-items:center;}
.nav-links a{font-size:13.5px;color:var(--muted);text-decoration:none;cursor:pointer;transition:color .18s;}
.nav-links a:hover{color:var(--ink);}
.nav-cta{font-family:var(--sans);font-size:13px;background:var(--green);color:#fff;border:0;border-radius:999px;padding:9px 17px;cursor:pointer;display:inline-flex;gap:7px;align-items:center;transition:transform .18s,background .2s;}
.nav-cta:hover{transform:translateY(-1px);background:var(--green-deep);}
.progress{position:fixed;top:0;left:0;height:2px;background:var(--green);z-index:60;transition:width .08s linear;}
@media(max-width:820px){.nav-links{display:none;}}

/* reveal */
.reveal{opacity:0;transform:translateY(22px);transition:opacity .7s cubic-bezier(.22,.61,.36,1),transform .7s cubic-bezier(.22,.61,.36,1);}
.reveal.in{opacity:1;transform:none;}

/* hero */
.hero{padding-top:130px;padding-bottom:clamp(52px,7vw,88px);position:relative;overflow:hidden;}
.hero-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:52px;align-items:center;}
@media(max-width:920px){.hero-grid{grid-template-columns:1fr;gap:36px;}}
.hero-tag{display:inline-flex;align-items:center;gap:8px;border:1px solid var(--line);background:var(--surface);border-radius:999px;padding:6px 14px;margin-bottom:24px;}
.hero-tag .dot{width:7px;height:7px;border-radius:50%;background:var(--green-2);box-shadow:0 0 0 0 rgba(78,155,110,.5);animation:ping 2.4s ease-out infinite;}
@keyframes ping{0%{box-shadow:0 0 0 0 rgba(78,155,110,.5);}70%{box-shadow:0 0 0 7px rgba(78,155,110,0);}100%{box-shadow:0 0 0 0 rgba(78,155,110,0);}}
.hero h1{margin:0 0 22px;}
.hero .lead{max-width:46ch;margin:0 0 34px;}
.hero-cta-row{display:flex;gap:12px;flex-wrap:wrap;align-items:center;}
.btn-primary{display:inline-flex;align-items:center;gap:9px;background:var(--green);color:#fff;border:0;border-radius:999px;padding:13px 22px;font-size:15px;font-family:var(--sans);cursor:pointer;transition:transform .2s,box-shadow .3s;}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 14px 30px -14px rgba(46,122,82,.65);}
.btn-ghost{display:inline-flex;align-items:center;gap:8px;background:none;color:var(--ink);border:1px solid var(--line);border-radius:999px;padding:13px 20px;font-size:15px;font-family:var(--sans);cursor:pointer;transition:border-color .2s,transform .2s;}
.btn-ghost:hover{border-color:var(--green-3);transform:translateY(-2px);}

/* hero live copilot card */
.hero-cop{background:var(--surface);border:1px solid var(--line);border-radius:20px;box-shadow:0 40px 80px -50px rgba(30,36,25,.45);overflow:hidden;}
.hero-cop .hc-head{display:flex;align-items:center;gap:11px;padding:16px 18px;border-bottom:1px solid var(--line);}
.hc-av{width:34px;height:34px;border-radius:9px;background:var(--green-deep);display:grid;place-items:center;color:#fff;}
.hc-name{font-weight:600;font-size:14px;}
.hc-status{font-family:var(--mono);font-size:10.5px;color:var(--muted);display:flex;align-items:center;gap:6px;}
.hc-status .d{width:6px;height:6px;border-radius:50%;background:var(--green-2);}
.hc-body{padding:18px;}
.hc-role{font-family:var(--mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--green-2);margin-bottom:8px;display:flex;align-items:center;gap:6px;}
.hc-msg{font-size:14.5px;line-height:1.5;color:var(--ink);}
.hc-chip{margin-top:14px;border:1px solid var(--rust-wash);background:#FCF6F1;border-radius:12px;padding:12px 14px;display:flex;align-items:center;justify-content:space-between;}
.hc-chip .l{font-size:12px;color:var(--muted);}
.hc-chip .v{font-family:var(--serif);font-weight:600;font-size:24px;color:var(--rust);letter-spacing:-0.02em;}
.hc-chip .badge-crit{font-family:var(--mono);font-size:9px;letter-spacing:.1em;color:var(--rust);background:var(--rust-wash);padding:3px 8px;border-radius:999px;}
.hc-act{margin-top:14px;width:100%;background:var(--green);color:#fff;border:0;border-radius:10px;padding:11px;font-size:13.5px;font-family:var(--sans);cursor:pointer;display:flex;align-items:center;justify-content:center;gap:7px;transition:background .2s;}
.hc-act:hover{background:var(--green-deep);}
.hc-type{display:inline-flex;gap:3px;margin-left:2px;}
.hc-type i{width:5px;height:5px;border-radius:50%;background:var(--green-3);animation:blink 1.4s infinite;}
.hc-type i:nth-child(2){animation-delay:.2s;}.hc-type i:nth-child(3){animation-delay:.4s;}
@keyframes blink{0%,60%,100%{opacity:.3;}30%{opacity:1;}}

/* meta row */
.meta-row{display:grid;grid-template-columns:repeat(5,1fr);gap:0;margin-top:56px;border-top:1px solid var(--line);}
.meta-cell{padding:18px 18px 18px 0;border-right:1px solid var(--line);}
.meta-cell:last-child{border-right:0;}
.meta-cell .k{font-family:var(--mono);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--faint);margin-bottom:6px;}
.meta-cell .v{font-size:14px;font-weight:500;}
@media(max-width:820px){.meta-row{grid-template-columns:repeat(2,1fr);}.meta-cell{border-right:0;border-bottom:1px solid var(--line);padding:14px 0;}}

/* section head */
.sec-head{display:flex;align-items:flex-start;gap:18px;margin-bottom:48px;}
.sec-num{flex:0 0 auto;display:grid;grid-template-columns:repeat(3,6px);grid-template-rows:repeat(3,6px);gap:2px;margin-top:9px;}
.sec-num i{border-radius:1px;background:var(--green-3);opacity:.35;}
.sec-num i.on{background:var(--green-deep);opacity:1;}
.sec-head .txt{flex:1;}
.sec-head .eyebrow{display:block;margin-bottom:13px;}
.sec-sub{margin-top:15px;max-width:62ch;}

/* generic cards / grids */
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
.grid-2{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;}
@media(max-width:880px){.grid-3,.grid-2{grid-template-columns:1fr;}}
.card{background:var(--surface);border:1px solid var(--line);border-radius:16px;padding:26px;transition:transform .3s,box-shadow .3s,border-color .3s;}
.card:hover{transform:translateY(-3px);box-shadow:0 20px 40px -28px rgba(30,36,25,.35);}
.card .ic{width:38px;height:38px;border-radius:10px;background:var(--paper);border:1px solid var(--line);display:grid;place-items:center;color:var(--green-deep);margin-bottom:16px;}
.card h4{font-weight:600;font-size:16px;margin:0 0 8px;letter-spacing:-0.01em;}
.card p{margin:0;font-size:14.5px;color:var(--muted);}
.tagsm{font-family:var(--mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--green-2);}

/* thesis strip */
.thesis{background:var(--surface);border:1px solid var(--line);border-radius:20px;padding:clamp(28px,4vw,44px);text-align:center;}
.thesis .big{font-family:var(--serif);font-weight:500;font-size:clamp(24px,3.4vw,38px);letter-spacing:-0.025em;line-height:1.1;}
.thesis .sub{color:var(--muted);margin-top:18px;font-size:17px;max-width:56ch;margin-left:auto;margin-right:auto;}
.thesis-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);border:1px solid var(--line);border-radius:16px;overflow:hidden;margin-top:34px;}
.thesis-cards>div{background:var(--surface);padding:24px;text-align:left;}
.thesis-cards .n{font-family:var(--mono);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--green-2);margin-bottom:10px;}
.thesis-cards h4{font-weight:600;font-size:15px;margin:0 0 6px;}
.thesis-cards p{font-size:13.5px;color:var(--muted);margin:0;}
@media(max-width:880px){.thesis-cards{grid-template-columns:1fr;}}

/* compare toggle */
.compare-toggle{display:inline-flex;background:var(--panel);border:1px solid var(--line);border-radius:999px;padding:4px;gap:2px;margin-bottom:24px;}
.compare-toggle button{font-family:var(--sans);font-size:13.5px;border:0;background:none;color:var(--muted);cursor:pointer;padding:8px 18px;border-radius:999px;transition:background .2s,color .2s;display:inline-flex;gap:7px;align-items:center;}
.compare-toggle button.active{background:var(--surface);color:var(--ink);box-shadow:0 1px 3px rgba(30,36,25,.12);}
.compare-toggle button.active.cop{color:var(--green-deep);}
.compare-stage{background:var(--surface);border:1px solid var(--line);border-radius:18px;padding:clamp(22px,3vw,32px);min-height:260px;box-shadow:0 24px 60px -44px rgba(30,36,25,.4);}
.cmp-scenario{font-family:var(--mono);font-size:11px;letter-spacing:.08em;color:var(--muted);display:flex;align-items:center;gap:8px;margin-bottom:20px;}
.cmp-fade{animation:fade .45s ease;}
@keyframes fade{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:none;}}
.dash-readout{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;}
@media(max-width:640px){.dash-readout{grid-template-columns:1fr;}}
.ro{border:1px solid var(--line);border-radius:12px;padding:16px;background:var(--surface-2);}
.ro .k{font-size:12px;color:var(--muted);margin-bottom:6px;}
.ro .v{font-family:var(--serif);font-weight:500;font-size:30px;letter-spacing:-0.02em;}
.ro .v small{font-size:14px;color:var(--muted);font-family:var(--sans);}
.cmp-note{margin-top:18px;font-size:13.5px;color:var(--muted);display:flex;gap:8px;align-items:flex-start;}
.cop-answer{display:flex;gap:14px;}
.cop-answer .av{width:38px;height:38px;border-radius:10px;background:var(--green-deep);color:#fff;display:grid;place-items:center;flex:0 0 auto;}
.cop-answer .txt{font-size:16px;line-height:1.5;}
.cop-answer .txt b{color:var(--green-deep);}
.cop-reason{margin-top:16px;border-left:2px solid var(--green-3);padding-left:16px;display:grid;gap:8px;}
.cop-reason .r{font-size:13.5px;color:var(--muted);}
.cop-reason .r b{color:var(--ink);font-weight:600;}
.cop-verdict{margin-top:20px;display:inline-flex;gap:10px;font-family:var(--serif);font-size:clamp(18px,2.4vw,24px);letter-spacing:-0.02em;}
.cop-verdict .x{color:var(--faint);text-decoration:line-through;}
.cop-verdict .y{color:var(--green-deep);}

/* reasoning loop */
.loop{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;}
@media(max-width:880px){.loop{grid-template-columns:1fr;}}
.loop-step{background:var(--surface);border:1px solid var(--line);border-radius:16px;padding:22px;cursor:pointer;transition:border-color .25s,box-shadow .25s,transform .25s;position:relative;}
.loop-step:hover{transform:translateY(-3px);}
.loop-step.active{border-color:var(--green-3);box-shadow:0 20px 44px -30px rgba(30,36,25,.4);}
.loop-step .st-ic{width:40px;height:40px;border-radius:11px;background:var(--green-wash);color:var(--green-deep);display:grid;place-items:center;margin-bottom:16px;transition:background .25s,color .25s;}
.loop-step.active .st-ic{background:var(--green-deep);color:#fff;}
.loop-step .st-n{font-family:var(--mono);font-size:10px;letter-spacing:.12em;color:var(--faint);margin-bottom:6px;}
.loop-step h4{font-family:var(--serif);font-weight:500;font-size:20px;margin:0 0 8px;letter-spacing:-0.01em;}
.loop-step .st-d{font-size:13.5px;color:var(--muted);}
.loop-step ul{margin:14px 0 0;padding:0;list-style:none;max-height:0;overflow:hidden;transition:max-height .35s ease;}
.loop-step.active ul{max-height:200px;}
.loop-step li{font-size:13px;color:var(--muted);padding:5px 0 5px 16px;position:relative;border-top:1px solid var(--line-2);}
.loop-step li:before{content:"";position:absolute;left:0;top:12px;width:5px;height:5px;border-radius:50%;background:var(--green-2);}

/* copilot chat panel */
.copilot{max-width:520px;margin:0 auto;background:var(--surface);border:1px solid var(--line);border-radius:22px;overflow:hidden;box-shadow:0 44px 90px -55px rgba(30,36,25,.5);}
.cp-head{display:flex;align-items:center;gap:12px;padding:16px 18px;border-bottom:1px solid var(--line);}
.cp-head .av{width:38px;height:38px;border-radius:10px;background:var(--green-deep);color:#fff;display:grid;place-items:center;}
.cp-head .nm{font-weight:600;font-size:15px;}
.cp-head .st{font-family:var(--mono);font-size:10.5px;color:var(--muted);display:flex;align-items:center;gap:6px;}
.cp-head .st .d{width:6px;height:6px;border-radius:50%;background:var(--green-2);}
.cp-head .min{margin-left:auto;width:32px;height:32px;border-radius:8px;background:var(--panel);border:1px solid var(--line);display:grid;place-items:center;color:var(--muted);}
.cp-body{padding:18px;display:flex;flex-direction:column;gap:18px;}
.msg .who{display:flex;align-items:center;gap:9px;margin-bottom:8px;font-size:12px;color:var(--muted);}
.msg .who .ic{width:24px;height:24px;border-radius:7px;background:var(--green-deep);color:#fff;display:grid;place-items:center;}
.msg .who .nm{font-weight:600;color:var(--ink);font-size:13px;}
.msg .who .tm{font-family:var(--mono);font-size:10.5px;color:var(--faint);}
.msg.user .who{justify-content:flex-end;}
.msg.user .who .av2{width:24px;height:24px;border-radius:50%;background:var(--green);color:#fff;display:grid;place-items:center;font-size:10px;font-weight:600;font-family:var(--mono);}
.bubble{border:1px solid var(--line);border-radius:14px;padding:14px 16px;font-size:14px;line-height:1.55;background:var(--surface);}
.bubble.user{background:var(--green-wash);border-color:#D9E7DD;}
.bubble b{color:var(--green-deep);font-weight:600;}
.bubble .rustnum{color:var(--rust);font-weight:600;}
.cp-card{margin:12px 0;border:1px solid var(--line);border-radius:12px;padding:14px;background:var(--surface-2);}
.cp-card .top{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;}
.cp-card .nm{font-size:13px;font-weight:600;}
.cp-card .crit{font-family:var(--mono);font-size:9px;letter-spacing:.1em;color:var(--rust);background:var(--rust-wash);padding:3px 8px;border-radius:999px;}
.cp-card .big{font-family:var(--serif);font-weight:600;font-size:30px;color:var(--rust);letter-spacing:-0.02em;}
.cp-card .big small{font-family:var(--sans);font-size:12px;color:var(--muted);font-weight:400;margin-left:6px;}
.cp-list{margin:6px 0 0;padding:0;list-style:none;}
.cp-list li{font-size:13.5px;color:var(--muted);padding:5px 0 5px 16px;position:relative;line-height:1.5;}
.cp-list li:before{content:"";position:absolute;left:0;top:11px;width:5px;height:5px;border-radius:50%;background:var(--rust);}
.cp-sa{border-top:1px solid var(--line);padding:16px 18px 6px;}
.cp-sa .lbl{font-family:var(--mono);font-size:10px;letter-spacing:.13em;text-transform:uppercase;color:var(--muted);margin-bottom:10px;}
.sa-chip{width:100%;text-align:left;border:1px solid var(--line);border-radius:11px;padding:12px 14px;background:var(--surface);cursor:pointer;display:flex;align-items:center;gap:11px;margin-bottom:8px;font-size:13.5px;font-family:var(--sans);color:var(--ink);transition:border-color .2s,background .2s,transform .15s;}
.sa-chip:hover{border-color:var(--green-3);background:var(--surface-2);transform:translateX(2px);}
.sa-chip .ci{width:22px;height:22px;display:grid;place-items:center;flex:0 0 auto;}
.sa-chip.done{border-color:#D9E7DD;background:var(--green-wash);color:var(--green-deep);}
.cp-input{border-top:1px solid var(--line);padding:14px 18px 18px;}
.cp-input .row{display:flex;gap:10px;align-items:center;border:1px solid var(--line);border-radius:12px;padding:6px 6px 6px 16px;background:var(--surface-2);}
.cp-input input{flex:1;border:0;background:none;outline:none;font-family:var(--sans);font-size:14px;color:var(--ink);}
.cp-input .send{width:38px;height:38px;border-radius:9px;background:var(--green);color:#fff;border:0;display:grid;place-items:center;cursor:pointer;flex:0 0 auto;transition:background .2s;}
.cp-input .send:hover{background:var(--green-deep);}
.cp-input .foot{font-size:11px;color:var(--faint);text-align:center;margin-top:10px;display:flex;align-items:center;justify-content:center;gap:6px;}

/* AgriOS dashboard recreation */
.insight{background:var(--surface);border:1px solid var(--line);border-radius:18px;padding:26px;position:relative;}
.insight .ib-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:8px;}
.insight .ib-eye{font-family:var(--mono);font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--green-deep);display:flex;align-items:center;gap:8px;font-weight:500;}
.insight .ib-eye .sp{width:22px;height:22px;border-radius:6px;background:var(--green-wash);display:grid;place-items:center;}
.insight .ib-upd{font-family:var(--mono);font-size:10.5px;color:var(--faint);}
.insight h3{font-weight:600;font-size:19px;letter-spacing:-0.01em;margin:0 0 8px;}
.insight .ib-sub{font-size:15px;color:var(--muted);max-width:80ch;}
.alert-cards{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:22px;}
@media(max-width:820px){.alert-cards{grid-template-columns:1fr;}}
.alert-card{border:1px solid var(--line);border-left:3px solid var(--rust);border-radius:12px;padding:20px;background:var(--surface-2);}
.alert-card .ac-t{font-size:14px;font-weight:600;margin-bottom:12px;}
.alert-card .ac-big{font-family:var(--serif);font-weight:600;font-size:34px;color:var(--rust);letter-spacing:-0.02em;line-height:1;}
.alert-card .ac-big small{font-family:var(--sans);font-size:13px;color:var(--muted);font-weight:400;margin-left:4px;}
.alert-card .ac-th{font-size:12.5px;color:var(--rust);margin:14px 0 6px;font-weight:500;}
